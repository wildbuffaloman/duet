{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "duet",
  "version": "0.2.0",
  "identifier": "com.duhau.duet",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://127.0.0.1:7433",
    "beforeBuildCommand": "bash scripts/stage-sidecar.sh"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/node"],
    "resources": ["resources/server"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
